{
  "title": "Onboarding Copilot",
  "uid": "onboarding-copilot",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "LLM latency p95 by stage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(orchestrator_llm_latency_seconds_bucket[5m])) by (le, status))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "Doc agent miss rate",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(doc_agent_empty_results_total[5m])) / sum(rate(doc_agent_calls_total[5m]))",
          "legendFormat": "Miss rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Stage conflicts",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(stage_advancement_conflict_total[1h])) or vector(0)",
          "legendFormat": "Conflicts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Stage advancements per hour",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(stage_advancement_total[1h])) by (from, to)",
          "legendFormat": "{{from}} Ã¢â€ â€™ {{to}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Guardrail blocks",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(guardrail_blocked_total[5m])) by (direction)",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Tool call rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(doc_agent_calls_total[5m]))",
          "legendFormat": "docAgentTool"
        },
        {
          "expr": "sum(rate(diagnostic_agent_calls_total[5m]))",
          "legendFormat": "getLatestLogs"
        }
      ]
    },
    {
      "id": 7,
      "title": "Active partners by stage",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(stage_advancement_total[24h])) by (to)",
          "legendFormat": "{{to}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": 0 }]
          }
        }
      }
    }
  ]
}
